# Google Gemini API-Key für den Scanner-Agenten (kostenloser AI-Studio Free-Tier).
# Key erstellen: https://aistudio.google.com/apikey
# In Vercel unter Project Settings → Environment Variables hinterlegen,
# lokal in eine Datei .env schreiben.
# Ohne Key fällt der Scanner automatisch auf die lokale Empfehlung zurück.
GEMINI_API_KEY=...

# Optional: anderes Gemini-Modell (Standard: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash-lite

# Resend API-Key für den ECHTEN Newsletter-Versand (kostenloser Free-Tier).
# Key erstellen: https://resend.com/api-keys
# Ohne Key wird nichts versendet (das Frontend zeigt einen Hinweis).
# Ohne verifizierte Domain sendet Resend nur an die EIGENE Konto-Adresse.
RESEND_API_KEY=...

# Optional: Absender, sobald eine eigene Domain in Resend verifiziert ist.
# RESEND_FROM=Stadtsignal <radar@deine-domain.de>
